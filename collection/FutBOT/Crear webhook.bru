meta {
  name: Crear webhook
  type: http
  seq: 2
}

post {
  url: http://localhost:8080/webhook/set/futbol-bot
  body: json
  auth: inherit
}

headers {
  apikey: changeme_api_key
  Content-Type: application/json
}

body:json {
  {
    "webhook": {
      "url": "http://host.docker.internal:8000/webhook",
      "enabled": true,
      "events": [
        "MESSAGES_UPSERT",
        "MESSAGES_UPDATE"
      ]
    }
  }
}

settings {
  encodeUrl: false
}
